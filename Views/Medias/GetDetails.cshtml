@model  Models.Media


@if (Model != null)
{
    bool isOwnerOrAdmin = Model.OwnerId == Models.User.ConnectedUser.Id || Models.User.ConnectedUser.IsAdmin;
    string sharedValue = Model.Shared && isOwnerOrAdmin ? "[Partagé]" : "";

    <div class="detailsPanel">
        <dl>
            <dd>
                <span style="color:grey">@sharedValue </span>
            </dd>
            <dd>
                @Model.Title
            </dd>
            <dd>
                @Helper.YoutubePlayer(Model.YoutubeId)
            </dd>
            <dd class="description">
                @Model.Description
            </dd>
            <dt>
                Catégorie
            </dt>

            <dd>
                @Model.Category
            </dd>

            <dt>
                Date de publication
            </dt>

            <dd>
                @Helper.When(Model.PublishDate)
            </dd>

            <dt>
                Ajouté par
            </dt>

            <dd>
                @Helper.AvatarUser2(Model.Owner)
            </dd>

        </dl>
    </div>
}
else
{
    <h1 style="color:red">Vidéo non disponible</h1>
}